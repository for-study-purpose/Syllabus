# Backend Configuration
PORT=5000
# Comma-separated list of allowed frontend origins.
# Example: CORS_ORIGIN=https://entcsppu.web.app,https://staging.example.com
CORS_ORIGIN=

# Firebase Admin SDK
# Get this from: Firebase Console → Project Settings → Service Accounts
# Copy the entire JSON and set as environment variable
FIREBASE_SERVICE_ACCOUNT_JSON={}
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# Google Drive Configuration
# Service-account-only mode (production recommended)
# Create a Google Cloud service account with Drive API enabled,
# share the target Drive folder with that service account email,
# then set the JSON below.
GDRIVE_SERVICE_ACCOUNT_JSON={}

# Google Drive folder where files will be stored
DRIVE_FOLDER_ID=your_drive_folder_id
