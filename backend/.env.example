# Backend Configuration
PORT=5000

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=

# Firebase Admin SDK
# Get from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_DATABASE_URL=

# Google Drive Service Account (reads, deletes, permissions)
# Create a service account, enable Drive API, share your folder with its email
GDRIVE_SERVICE_ACCOUNT_JSON=

# Google Drive folder ID
DRIVE_FOLDER_ID=

# OAuth credentials for uploads (required for personal Gmail — service accounts have zero quota)
# Set up OAuth consent screen and create Desktop credentials in Google Cloud Console
# Get a refresh token via https://developers.google.com/oauthplayground
GDRIVE_OAUTH_CLIENT_ID=
GDRIVE_OAUTH_CLIENT_SECRET=
GDRIVE_OAUTH_REFRESH_TOKEN=

# Upload limits
MAX_FILE_SIZE_MB=256
MAX_CHUNK_SIZE_MB=25
