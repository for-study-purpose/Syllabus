# ── Firebase Web App config ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# IMPORTANT: Any VITE_* variable is bundled into client JavaScript and is public.
# Never put secrets (client secret, refresh token, service account JSON, admin setup token) here.
# Get values from: Firebase Console → Project Settings → Your apps → Web app
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_DATABASE_URL=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=
VITE_API_BASE_URL=http://localhost:5000/api

# ── Admin authentication ───────────────────────────────────────────────────────
# No credentials are stored in source code. Admin login uses Firebase Authentication.
# Create the admin user once in Firebase Console:
#   Firebase Console → Authentication → Users → Add user
# That email + password is what the admin enters at /admin.
